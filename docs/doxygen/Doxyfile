#---------------------------------------------------------------------------
# Project related configuration options
#---------------------------------------------------------------------------

PROJECT_NAME           = "Helios Engine"
PROJECT_BRIEF          = "A modular ECS based data-oriented C++23 game engine"
PROJECT_LOGO           = ../img/logo.png
PROJECT_NUMBER         = 0.1.0

OUTPUT_DIRECTORY       =
CREATE_SUBDIRS         = NO

#---------------------------------------------------------------------------
# Configuration options related to the input files
#---------------------------------------------------------------------------

# Use relative paths so Doxygen works from docs/ or project root
INPUT                  = ../../src \
                         ../../README.md \
                         ../../docs/guidelines.md \
                         ../../examples/custom_module/README.md
FILE_PATTERNS          = *.hpp *.inl *.h *.cpp *.cxx *.c *.md
RECURSIVE              = YES
EXCLUDE                = ../../tests ../../third-party
EXCLUDE_PATTERNS       = */tests/* \
                         */details/*

#---------------------------------------------------------------------------
# Configuration options related to source browsing
#---------------------------------------------------------------------------

# SOURCE_BROWSER keeps "Definition at line N of file …" links; INLINE_SOURCES
# controls whether the function body is also embedded on the member page.
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
SHOW_USED_FILES        = NO
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = ../../


#---------------------------------------------------------------------------
# Configuration options related to the alphabetical class index
#---------------------------------------------------------------------------

ALPHABETICAL_INDEX     = YES

#---------------------------------------------------------------------------
# Configuration options related to the HTML output
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html

# Base theme (doxygen-awesome-css + extensions)
HTML_HEADER            = header.html
HTML_FOOTER            = footer.html
HTML_EXTRA_STYLESHEET  = ../../third-party/doxygen-awesome-css/doxygen-awesome.css \
                         custom.css
HTML_EXTRA_FILES       = jquery.min.js \
                         ../../third-party/doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js \
                         ../../third-party/doxygen-awesome-css/doxygen-awesome-fragment-copy-button.js \
                         ../../third-party/doxygen-awesome-css/doxygen-awesome-interactive-toc.js \
                         ../../third-party/doxygen-awesome-css/doxygen-awesome-tabs.js
HTML_COPY_CLIPBOARD    = NO
PAGE_OUTLINE_PANEL     = NO

# Base theme (see doxygen-awesome-css README)
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
TREEVIEW_WIDTH         = 335

PROJECT_ICON           = ../img/favicon.ico

IMAGE_PATH             = ../img

#---------------------------------------------------------------------------
# Configuration options related to LaTeX/PDF output
#---------------------------------------------------------------------------

GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Configuration options related to the RTF output
#---------------------------------------------------------------------------

GENERATE_RTF           = NO

#---------------------------------------------------------------------------
# Configuration options related to the man page output
#---------------------------------------------------------------------------

GENERATE_MAN           = NO

#---------------------------------------------------------------------------
# Configuration options related to the XML output
#---------------------------------------------------------------------------

GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Configuration options related to the preprocessor
#---------------------------------------------------------------------------

# Preprocessor
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = HELIOS_API= \
                         HELIOS_FORCE_INLINE=inline \
                         HELIOS_NO_INLINE= \

# STL support
BUILTIN_STL_SUPPORT    = YES

#---------------------------------------------------------------------------
# Configuration options related to external references
#---------------------------------------------------------------------------

TAGFILES               =

#---------------------------------------------------------------------------
# Configuration options related to the dot tool
#---------------------------------------------------------------------------

HAVE_DOT               = NO
DOT_IMAGE_FORMAT       = svg
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
COLLABORATION_GRAPH    = YES
UML_LOOK               = YES

#---------------------------------------------------------------------------
# Configuration options related to the extraction process
#---------------------------------------------------------------------------

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = YES

#---------------------------------------------------------------------------
# Configuration options related to warnings and progress
#---------------------------------------------------------------------------

QUIET                  = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES

#---------------------------------------------------------------------------
# Configuration options related to grouping and main page
#---------------------------------------------------------------------------

USE_MDFILE_AS_MAINPAGE = ../../README.md
MARKDOWN_SUPPORT       = YES
MARKDOWN_ID_STYLE      = GITHUB
AUTOLINK_SUPPORT       = YES

#---------------------------------------------------------------------------
# Configuration options related to search
#---------------------------------------------------------------------------

SEARCHENGINE           = YES

#---------------------------------------------------------------------------
# Miscellaneous
#---------------------------------------------------------------------------

GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST= YES
