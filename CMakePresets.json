{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "description": "Base configuration for all presets",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": "base",
      "description": "Base configuration for Windows builds",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": ["Windows"]
        }
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": "base",
      "description": "Base configuration for Linux builds",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "macos-base",
      "hidden": true,
      "inherits": "base",
      "description": "Base configuration for macOS builds",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "msvc",
      "hidden": true,
      "description": "MSVC compiler configuration (auto-detected via Visual Studio toolset)"
    },
    {
      "name": "windows-ninja-base",
      "hidden": true,
      "inherits": "windows-base",
      "description": "Base configuration for Windows Ninja builds",
      "generator": "Ninja",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      }
    },
    {
      "name": "clang",
      "hidden": true,
      "description": "Clang compiler configuration",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "clang-cl",
      "hidden": true,
      "description": "Clang-CL compiler configuration (MSVC-compatible)",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl.exe",
        "CMAKE_CXX_COMPILER": "clang-cl.exe"
      }
    },
    {
      "name": "gcc",
      "hidden": true,
      "description": "GCC compiler configuration",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "debug-config",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "relwithdebinfo-config",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HELIOS_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "release-config",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HELIOS_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "docs",
      "displayName": "Documentation",
      "description": "Configure a docs-only Doxygen build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-docs",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HELIOS_DOCS_ONLY": "ON",
        "HELIOS_BUILD_DOCS": "ON"
      }
    },
    {
      "name": "linux-gcc-debug",
      "displayName": "Linux GCC Debug",
      "description": "Linux debug build with GCC",
      "inherits": ["linux-base", "gcc", "debug-config"]
    },
    {
      "name": "linux-gcc-relwithdebinfo",
      "displayName": "Linux GCC RelWithDebInfo",
      "description": "Linux RelWithDebInfo build with GCC",
      "inherits": ["linux-base", "gcc", "relwithdebinfo-config"]
    },
    {
      "name": "linux-gcc-release",
      "displayName": "Linux GCC Release",
      "description": "Linux release build with GCC",
      "inherits": ["linux-base", "gcc", "release-config"]
    },
    {
      "name": "linux-clang-debug",
      "displayName": "Linux Clang Debug",
      "description": "Linux debug build with Clang",
      "inherits": ["linux-base", "clang", "debug-config"]
    },
    {
      "name": "linux-clang-relwithdebinfo",
      "displayName": "Linux Clang RelWithDebInfo",
      "description": "Linux RelWithDebInfo build with Clang",
      "inherits": ["linux-base", "clang", "relwithdebinfo-config"]
    },
    {
      "name": "linux-clang-release",
      "displayName": "Linux Clang Release",
      "description": "Linux release build with Clang",
      "inherits": ["linux-base", "clang", "release-config"]
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "description": "Windows debug build with MSVC",
      "inherits": ["windows-ninja-base", "msvc", "debug-config"]
    },
    {
      "name": "windows-msvc-relwithdebinfo",
      "displayName": "Windows MSVC RelWithDebInfo",
      "description": "Windows RelWithDebInfo build with MSVC",
      "inherits": ["windows-ninja-base", "msvc", "relwithdebinfo-config"]
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release",
      "description": "Windows release build with MSVC",
      "inherits": ["windows-ninja-base", "msvc", "release-config"]
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Windows Clang-CL Debug",
      "description": "Windows debug build with Clang-CL",
      "inherits": ["windows-ninja-base", "clang-cl", "debug-config"]
    },
    {
      "name": "windows-clang-relwithdebinfo",
      "displayName": "Windows Clang-CL RelWithDebInfo",
      "description": "Windows RelWithDebInfo build with Clang-CL",
      "inherits": ["windows-ninja-base", "clang-cl", "relwithdebinfo-config"]
    },
    {
      "name": "windows-clang-release",
      "displayName": "Windows Clang-CL Release",
      "description": "Windows release build with Clang-CL",
      "inherits": ["windows-ninja-base", "clang-cl", "release-config"]
    },
    {
      "name": "windows-vs-debug",
      "displayName": "Windows Visual Studio Debug",
      "description": "Windows debug build with Visual Studio",
      "inherits": ["windows-base", "msvc", "debug-config"]
    },
    {
      "name": "windows-vs-relwithdebinfo",
      "displayName": "Windows Visual Studio RelWithDebInfo",
      "description": "Windows RelWithDebInfo build with Visual Studio",
      "inherits": ["windows-base", "msvc", "relwithdebinfo-config"]
    },
    {
      "name": "windows-vs-release",
      "displayName": "Windows Visual Studio Release",
      "description": "Windows release build with Visual Studio",
      "inherits": ["windows-base", "msvc", "release-config"]
    },
    {
      "name": "macos-clang-debug",
      "displayName": "macOS Clang Debug",
      "description": "macOS debug build with Clang",
      "inherits": ["macos-base", "clang", "debug-config"]
    },
    {
      "name": "macos-clang-relwithdebinfo",
      "displayName": "macOS Clang RelWithDebInfo",
      "description": "macOS RelWithDebInfo build with Clang",
      "inherits": ["macos-base", "clang", "relwithdebinfo-config"]
    },
    {
      "name": "macos-clang-release",
      "displayName": "macOS Clang Release",
      "description": "macOS release build with Clang",
      "inherits": ["macos-base", "clang", "release-config"]
    }
  ],
  "buildPresets": [
    {
      "name": "docs",
