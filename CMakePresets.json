    },
    {
      "name": "linux-clang-relwithdebinfo",
      "configurePreset": "linux-clang-relwithdebinfo",
      "displayName": "Build Linux Clang RelWithDebInfo",
      "description": "Build Linux RelWithDebInfo with Clang"
    },
    {
      "name": "linux-clang-release",
      "configurePreset": "linux-clang-release",
      "displayName": "Build Linux Clang Release",
      "description": "Build Linux release with Clang"
    },
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "displayName": "Build Windows MSVC Debug",
      "description": "Build Windows debug with MSVC"
    },
    {
      "name": "windows-msvc-relwithdebinfo",
      "configurePreset": "windows-msvc-relwithdebinfo",
      "displayName": "Build Windows MSVC RelWithDebInfo",
      "description": "Build Windows RelWithDebInfo with MSVC"
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release",
      "displayName": "Build Windows MSVC Release",
      "description": "Build Windows release with MSVC"
    },
    {
      "name": "windows-clang-debug",
      "configurePreset": "windows-clang-debug",
      "displayName": "Build Windows Clang-CL Debug",
      "description": "Build Windows debug with Clang-CL"
    },
    {
      "name": "windows-clang-relwithdebinfo",
      "configurePreset": "windows-clang-relwithdebinfo",
