    {
      "name": "windows-vs-debug",
      "configurePreset": "windows-vs-debug",
      "displayName": "Build Windows VS Debug",
      "description": "Build Windows debug with Visual Studio",
      "configuration": "Debug"
    },
    {
      "name": "windows-vs-relwithdebinfo",
      "configurePreset": "windows-vs-relwithdebinfo",
      "displayName": "Build Windows VS RelWithDebInfo",
      "description": "Build Windows RelWithDebInfo with Visual Studio",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "windows-vs-release",
      "configurePreset": "windows-vs-release",
      "displayName": "Build Windows VS Release",
      "description": "Build Windows release with Visual Studio",
      "configuration": "Release"
    },
    {
      "name": "macos-clang-debug",
      "configurePreset": "macos-clang-debug",
      "displayName": "Build macOS Clang Debug",
      "description": "Build macOS debug with Clang"
    },
    {
      "name": "macos-clang-relwithdebinfo",
      "configurePreset": "macos-clang-relwithdebinfo",
      "displayName": "Build macOS Clang RelWithDebInfo",
      "description": "Build macOS RelWithDebInfo with Clang"
