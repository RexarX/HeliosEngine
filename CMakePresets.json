    {
      "name": "macos-clang-release",
      "configurePreset": "macos-clang-release",
      "displayName": "Build macOS Clang Release",
      "description": "Build macOS release with Clang"
    }
  ],
  "testPresets": [
    {
      "name": "test-base",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "linux-gcc-debug",
      "configurePreset": "linux-gcc-debug",
      "inherits": "test-base",
      "displayName": "Test Linux GCC Debug"
    },
    {
      "name": "linux-gcc-relwithdebinfo",
      "configurePreset": "linux-gcc-relwithdebinfo",
      "inherits": "test-base",
      "displayName": "Test Linux GCC RelWithDebInfo"
    },
    {
      "name": "linux-gcc-release",
      "configurePreset": "linux-gcc-release",
      "inherits": "test-base",
      "displayName": "Test Linux GCC Release"
    },
    {
      "name": "linux-clang-debug",
      "configurePreset": "linux-clang-debug",
      "inherits": "test-base",
      "displayName": "Test Linux Clang Debug"
    },
    {
      "name": "linux-clang-relwithdebinfo",
      "configurePreset": "linux-clang-relwithdebinfo",
      "inherits": "test-base",
      "displayName": "Test Linux Clang RelWithDebInfo"
    },
    {
      "name": "linux-clang-release",
      "configurePreset": "linux-clang-release",
      "inherits": "test-base",
      "displayName": "Test Linux Clang Release"
    },
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "inherits": "test-base",
      "displayName": "Test Windows MSVC Debug"
    },
    {
      "name": "windows-msvc-relwithdebinfo",
      "configurePreset": "windows-msvc-relwithdebinfo",
      "inherits": "test-base",
      "displayName": "Test Windows MSVC RelWithDebInfo"
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc-release",
      "inherits": "test-base",
      "displayName": "Test Windows MSVC Release"
    },
    {
      "name": "windows-clang-debug",
      "configurePreset": "windows-clang-debug",
      "inherits": "test-base",
      "displayName": "Test Windows Clang-CL Debug"
    },
    {
      "name": "windows-clang-relwithdebinfo",
      "configurePreset": "windows-clang-relwithdebinfo",
      "inherits": "test-base",
